{
    "name": "n8n-nodes-instaparser",
    "version": "0.1.1",
    "description": "Instaparser API integration for n8n",
    "license": "MIT",
    "homepage": "https://instaparser.com",
    "keywords": [
        "n8n-community-node-package",
        "instaparser",
        "instaparser-api"
    ],
    "author": {
        "name": "Instaparser",
        "email": "support@instaparser.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Instapaper/n8n-nodes-instaparser.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/InstaparserApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/Instaparser/Instaparser.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}
